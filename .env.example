# ============================================================
# .env.example — EKG Multi-Agente
# Copia este archivo a .env y completa los valores
# NUNCA commitees el .env real a Git
# ============================================================

# ── Firebase ─────────────────────────────────────────────────
FIREBASE_TOKEN=          # firebase login:ci → genera este token
FIREBASE_PROJECT=        # ej: ekgmultiagente

# ── Google Cloud (para deploy de backend a Cloud Run) ────────
GCLOUD_PROJECT=          # ej: ekgmultiagente
GCLOUD_REGION=           # ej: us-central1
GCP_SA_KEY=              # JSON completo del service account (ver README)

# ── Modelo IA ────────────────────────────────────────────────
# API key de OpenRouter: https://openrouter.ai/keys
MODEL_API_KEY=sk-or-v1-...
# Modelo recomendado para producción:
MODEL_NAME=google/gemini-2.5-flash-preview

# ── Opcionales ───────────────────────────────────────────────
OPENROUTER_API_KEY=      # Alias de MODEL_API_KEY si usas OpenRouter
FASTAPI_API_KEY=         # Clave interna de la API (para proteger el endpoint)
