# ==========================================
# CONFIGURACIÓN PARA PROBAR CON OPENROUTER (Gemini)
# ==========================================
# Descomenta las siguientes líneas y pon tu clave sk-or...
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-tua-api-key-aqui
# MODEL_NAME=google/gemini-3.1-pro-preview

# ==========================================
# CONFIGURACIÓN PARA PROBAR CON OLLAMA (Modelos Locales)
# ==========================================
# Si prefieres probar con alguno de tus modelos locales de Ollama, 
# descomenta estas líneas y cambia el modelo si lo deseas:
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# MODEL_NAME=llama3.2-vision:latest
